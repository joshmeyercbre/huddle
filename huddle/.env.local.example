COSMOS_CONNECTION_STRING=AccountEndpoint=https://YOUR_ACCOUNT.documents.azure.com:443/;AccountKey=YOUR_KEY==;
COSMOS_DB_NAME=1on1db
NEXT_PUBLIC_BASE_URL=http://localhost:3000

