{
  "routes": [
    {
      "route": "/1on1/*",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/1on1/*",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/meetings/*",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/action-items/*",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/*",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/*",
      "allowedRoles": ["authenticated"]
    }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad",
      "statusCode": 302
    }
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "SAMEORIGIN"
  }
}
